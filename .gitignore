```gitignore
# ── Data & Datasets ──────────────────────────────────────────
*.pcap
*.pcapng

# ── ML Models & Checkpoints ──────────────────────────────────

*.h5
*.onnx
*.model


# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.Python
*.egg-info/
dist/
build/

# ── Virtual Environments ─────────────────────────────────────
venv/
env/
.env
.venv

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
.npm
package-lock.json

# ── Logs & Output ────────────────────────────────────────────
*.log
logs/
*.out



# ── OS & Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# ── Archives ─────────────────────────────────────────────────
*.tar

# ── Gramine / TEE ────────────────────────────────────────────
*.token
*.sig
*.manifest
*.manifest.sgx
gramine_tmp/

# ── Cryptographic Material ───────────────────────────────────
*.pem
*.key
*.p12
*.csr
*.srl
!crypto/certs/ca.crt
!crypto/certs/server.crt

